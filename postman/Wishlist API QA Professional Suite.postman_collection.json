    {
      "name": "GIFT TESTS",
      "item": [
        {
          "name": "Create gift",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json=pm.response.json();",
                  "pm.test('Status 200', ()=>pm.response.to.have.status(200));",
                  "pm.test('Gift id exists', ()=>pm.expect(json.id).to.exist);",
                  "pm.test('Name correct', ()=>pm.expect(json.name).to.eql('PlayStation 5'));",
                  "pm.test('Price numeric', ()=>pm.expect(json.price).to.be.a('number'));",
                  "pm.test('Reserved boolean', ()=>pm.expect(json.reserved).to.be.a('boolean'));",
                  "pm.environment.set('gift_id',json.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\"name\":\"PlayStation 5\",\n\"description\":\"Gaming console\",\n\"price\":699\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/gifts/wishlist/{{wishlist_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "gifts",
                "wishlist",
                "{{wishlist_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get gifts in wishlist",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Парсим ответ",
                  "let jsonData = pm.response.json();",
                  "",
                  "// 1️⃣ Проверка, что статус 200",
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "",
                  "// 2️⃣ Проверка, что пришёл массив",
                  "pm.test(\"Response is array\", () => pm.expect(jsonData).to.be.an(\"array\"));",
                  "",
                  "// 3️⃣ Проверка, что массив не пустой",
                  "if (jsonData.length > 0) {",
                  "    const firstGift = jsonData[0];",
                  "",
                  "    // 4️⃣ Проверка, что у подарка есть id",
                  "    pm.test(\"Gift id exists\", () => pm.expect(firstGift.id).to.exist);",
                  "",
                  "    // 5️⃣ Сохраняем gift_id в collection variable",
                  "    pm.collectionVariables.set(\"gift_id\", firstGift.id);",
                  "    console.log(\"Saved gift_id:\", firstGift.id);",
                  "",
                  "    // 6️⃣ Дополнительно можно проверить UUID",
                  "    pm.test(\"Gift id is UUID\", () => {",
                  "        const uuidRegex = /^[0-9a-fA-F-]{36}$/;",
                  "        pm.expect(firstGift.id).to.match(uuidRegex);",
                  "    });",
                  "} else {",
                  "    console.warn(\"No gifts returned, gift_id not set\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/gifts/wishlist/{{wishlist_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "gifts",
